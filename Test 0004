public class Demo4 {
    public static void main(String[] args) {
        int n = 4; // The starting number and size indicator
        int size = 2 * n - 1; // This calculates the grid size (7x7)
        for (int i = 1; i <= size; i++) {
              for (int j = 1; j <= size; j++) {
                /* * Logic: For each cell, find the distance to the 
                 * nearest edge (top, bottom, left, or right).
                 */
                int top = i;
                int left = j;
                int bottom = size - i + 1;
                int right = size - j + 1;
                int minDistance = Math.min(Math.min(top, bottom), Math.min(left, right));
                System.out.print((n - minDistance + 1) + " ");
            }
            System.out.println();
        }
    }
}
